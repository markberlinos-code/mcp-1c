// Обработчик POST /eventlog
// Чтение записей журнала регистрации 1С с фильтрацией.
//
// Тело запроса (JSON):
// {
//   "start_date": "2026-03-01T00:00:00",  // необязательно
//   "end_date":   "2026-03-07T23:59:59",  // необязательно
//   "level":      "Ошибка",                // необязательно: Ошибка|Предупреждение|Информация|Примечание
//   "user":       "Администратор",         // необязательно
//   "limit":      50                       // необязательно, по умолчанию 50, максимум 500
// }
//
// Ответ (JSON):
// {
//   "events": [
//     {
//       "date":        "2026-03-07T10:00:00",
//       "level":       "Ошибка",
//       "event":       "Данные.Запись",
//       "user":        "Администратор",
//       "computer":    "SERVER01",
//       "metadata":    "Документ.РеализацияТоваровУслуг",
//       "data":        "",
//       "comment":     "Ошибка при записи документа",
//       "transaction": "..."
//     }
//   ],
//   "total": 42
// }
//
// ПРИМЕЧАНИЕ: Вспомогательные функции ОтветJSON, ОтветОшибка, РазобратьJSON, СформироватьJSON
// и НайтиМетаданныеПоТипуИИмени определены в основном модуле HTTP-сервиса (Module.bsl).

Функция ЖурналРегистрацииPOST(Запрос)
    Попытка
        Параметры = РазобратьJSON(Запрос.ПолучитьТелоКакСтроку());
    Исключение
        Параметры = Новый Структура;
    КонецПопытки;

    Отбор = Новый Структура;

    Если Параметры.Свойство("start_date") И ЗначениеЗаполнено(Параметры.start_date) Тогда
        Попытка
            Отбор.Вставить("ДатаНачала", XMLЗначение(Тип("Дата"), Параметры.start_date));
        Исключение
        КонецПопытки;
    КонецЕсли;

    Если Параметры.Свойство("end_date") И ЗначениеЗаполнено(Параметры.end_date) Тогда
        Попытка
            Отбор.Вставить("ДатаОкончания", XMLЗначение(Тип("Дата"), Параметры.end_date));
        Исключение
        КонецПопытки;
    КонецЕсли;

    Если Параметры.Свойство("level") И ЗначениеЗаполнено(Параметры.level) Тогда
        СоответствиеУровней = Новый Соответствие;
        СоответствиеУровней.Вставить("Ошибка",        УровеньЖурналаРегистрации.Ошибка);
        СоответствиеУровней.Вставить("Предупреждение", УровеньЖурналаРегистрации.Предупреждение);
        СоответствиеУровней.Вставить("Информация",     УровеньЖурналаРегистрации.Информация);
        СоответствиеУровней.Вставить("Примечание",     УровеньЖурналаРегистрации.Примечание);
        Уровень = СоответствиеУровней[Параметры.level];
        Если Уровень <> Неопределено Тогда
            МассивУровней = Новый Массив;
            МассивУровней.Добавить(Уровень);
            Отбор.Вставить("Уровень", МассивУровней);
        КонецЕсли;
    КонецЕсли;

    Если Параметры.Свойство("user") И ЗначениеЗаполнено(Параметры.user) Тогда
        Попытка
            ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(Параметры.user);
            Если ПользовательИБ <> Неопределено Тогда
                МассивПользователей = Новый Массив;
                МассивПользователей.Добавить(ПользовательИБ);
                Отбор.Вставить("Пользователь", МассивПользователей);
            КонецЕсли;
        Исключение
            // Нет права Администрирование — фильтр по пользователю не применяется
        КонецПопытки;
    КонецЕсли;

    Лимит = 50;
    Если Параметры.Свойство("limit") И Параметры.limit > 0 Тогда
        Лимит = Мин(Параметры.limit, 500);
    КонецЕсли;

    // Защита от OOM: если не указана дата начала, ограничиваем последними 7 днями
    Если НЕ Отбор.Свойство("ДатаНачала") Тогда
        Отбор.Вставить("ДатаНачала", ТекущаяДата() - 7 * 86400);
    КонецЕсли;

    ТаблицаЖурнала = Новый ТаблицаЗначений;
    ВыгрузитьЖурналРегистрации(ТаблицаЖурнала, Отбор);

    ВсегоЗаписей = ТаблицаЖурнала.Количество();

    МассивСобытий = Новый Массив;
    Для Индекс = 0 По Мин(Лимит, ВсегоЗаписей) - 1 Цикл
        Строка = ТаблицаЖурнала[Индекс];
        Событие = Новый Структура;
        Событие.Вставить("date",        XMLСтрока(Строка.Дата));
        Событие.Вставить("level",       Строка(Строка.Уровень));
        Событие.Вставить("event",       Строка(Строка.Событие));
        Событие.Вставить("user",        Строка(Строка.ИмяПользователя));
        Событие.Вставить("computer",    Строка(Строка.Компьютер));
        Событие.Вставить("metadata",    ПолучитьКолонкуЖурнала(Строка, ТаблицаЖурнала, "МетаданныеПредставление"));
        Событие.Вставить("data",        ПолучитьКолонкуЖурнала(Строка, ТаблицаЖурнала, "ДанныеПредставление"));
        Событие.Вставить("comment",     ПолучитьКолонкуЖурнала(Строка, ТаблицаЖурнала, "Комментарий"));
        Событие.Вставить("transaction", ПолучитьКолонкуЖурнала(Строка, ТаблицаЖурнала, "ИдентификаторТранзакции"));
        МассивСобытий.Добавить(Событие);
    КонецЦикла;

    Результат = Новый Структура;
    Результат.Вставить("events", МассивСобытий);
    Результат.Вставить("total",  ВсегоЗаписей);

    Возврат ОтветJSON(Результат);
КонецФункции
