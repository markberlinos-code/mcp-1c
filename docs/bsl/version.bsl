// Обработчик GET /version
// Возвращает версию расширения и информацию о платформе.
//
// Ответ: JSON {"extension_version": "0.3.0", "platform": "8.3.xx.xxxx", "configuration": "..."}

Функция ВерсияGET(Запрос)
    Результат = Новый Структура;
    Результат.Вставить("extension_version", "0.3.0");
    Результат.Вставить("platform", СистемнаяИнформация().ВерсияПриложения);
    Результат.Вставить("configuration", Метаданные.Имя + " " + Метаданные.Версия);

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрокаJSON(Результат));
    Возврат Ответ;
КонецФункции
