// Обработчик GET /module/{type}/{name}/{kind}
// Возвращает код модуля объекта метаданных.
//
// URL параметры:
//   type — тип объекта (Catalog, Document и т.д.)
//   name — имя объекта метаданных
//   kind — вид модуля: ObjectModule, ManagerModule, FormModule, RecordSetModule, CommandModule
//
// Ответ: JSON {"Имя": "...", "ВидМодуля": "...", "Код": "..."}
//
// ПРИМЕЧАНИЕ: Функция НайтиМетаданныеПоТипуИИмени определена в object.bsl.
// В реальном расширении она должна находиться в общем модуле.
//
// ВАЖНО: Получение текста модуля программно возможно только в режиме конфигуратора
// или через внешнее подключение (COM/V8). В серверном контексте HTTP-сервиса
// прямой доступ к тексту модулей ограничен платформой.
// Реализация ниже использует методы ПолучитьМодульОбъекта()/ПолучитьМодульМенеджера(),
// которые доступны в объекте метаданных, но возвращают текстовый документ
// только при наличии соответствующих прав и в поддерживаемых режимах платформы (8.3.14+).

Функция МодульGET(Запрос)
    ТипОбъекта = Запрос.ПараметрыURL["type"];
    ИмяОбъекта = Запрос.ПараметрыURL["name"];
    ВидМодуля  = Запрос.ПараметрыURL["kind"];

    ОбъектМД = НайтиМетаданныеПоТипуИИмени(ТипОбъекта, ИмяОбъекта);
    Если ОбъектМД = Неопределено Тогда
        Ответ = Новый HTTPСервисОтвет(404);
        Ответ.УстановитьТелоИзСтроки("{""error"": ""Object not found""}");
        Возврат Ответ;
    КонецЕсли;

    Код = ПолучитьКодМодуля(ОбъектМД, ВидМодуля);
    Если Код = Неопределено Тогда
        Ответ = Новый HTTPСервисОтвет(404);
        Ответ.УстановитьТелоИзСтроки("{""error"": ""Module not found""}");
        Возврат Ответ;
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("Имя", ОбъектМД.Имя);
    Результат.Вставить("ВидМодуля", ВидМодуля);
    Результат.Вставить("Код", Код);

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрокаJSON(Результат));
    Возврат Ответ;
КонецФункции

// ПолучитьКодМодуля — извлекает текст модуля указанного вида.
//
// Поддерживаемые виды модулей:
//   ObjectModule     — модуль объекта (справочники, документы, обработки, отчёты)
//   ManagerModule    — модуль менеджера
//   RecordSetModule  — модуль набора записей (регистры)
//
// Методы ПолучитьМодульОбъекта() / ПолучитьМодульМенеджера() / ПолучитьМодульНабораЗаписей()
// возвращают ТекстовыйДокумент, из которого извлекается текст через ПолучитьТекст().
// Если модуль отсутствует или недоступен, возвращается Неопределено.
Функция ПолучитьКодМодуля(ОбъектМД, ВидМодуля)
    Попытка
        Если ВидМодуля = "ObjectModule" Тогда
            Возврат ОбъектМД.ПолучитьМодульОбъекта().ПолучитьТекст();
        ИначеЕсли ВидМодуля = "ManagerModule" Тогда
            Возврат ОбъектМД.ПолучитьМодульМенеджера().ПолучитьТекст();
        ИначеЕсли ВидМодуля = "RecordSetModule" Тогда
            Возврат ОбъектМД.ПолучитьМодульНабораЗаписей().ПолучитьТекст();
        Иначе
            Возврат Неопределено;
        КонецЕсли;
    Исключение
        Возврат Неопределено;
    КонецПопытки;
КонецФункции
