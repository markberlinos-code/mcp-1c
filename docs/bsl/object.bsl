// Обработчик GET /object/{type}/{name}
// Возвращает структуру объекта метаданных: реквизиты, табличные части, измерения, ресурсы.
//
// URL параметры:
//   type — тип объекта: Catalog, Document, AccumulationRegister, InformationRegister,
//          AccountingRegister, Enum, DataProcessor, Report, ChartOfAccounts,
//          ChartOfCharacteristicTypes, ChartOfCalculationTypes, ExchangePlan,
//          BusinessProcess, Task
//   name — имя объекта метаданных
//
// Ответ: JSON-объект с полями name, synonym, attributes, tabularParts, dimensions, resources

Функция ОбъектGET(Запрос)
    ТипОбъекта = Запрос.ПараметрыURL["type"];
    ИмяОбъекта = Запрос.ПараметрыURL["name"];

    ОбъектМД = НайтиМетаданныеПоТипуИИмени(ТипОбъекта, ИмяОбъекта);
    Если ОбъектМД = Неопределено Тогда
        Ответ = Новый HTTPСервисОтвет(404);
        Ответ.УстановитьТелоИзСтроки("{""error"": ""Object not found""}");
        Возврат Ответ;
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("name", ОбъектМД.Имя);
    Результат.Вставить("synonym", ОбъектМД.Синоним);

    // Реквизиты
    Реквизиты = Новый Массив;
    Для Каждого Реквизит Из ОбъектМД.Реквизиты Цикл
        ОписаниеРеквизита = Новый Структура;
        ОписаниеРеквизита.Вставить("name", Реквизит.Имя);
        ОписаниеРеквизита.Вставить("synonym", Реквизит.Синоним);
        ОписаниеРеквизита.Вставить("type", Строка(Реквизит.Тип));
        Реквизиты.Добавить(ОписаниеРеквизита);
    КонецЦикла;
    Результат.Вставить("attributes", Реквизиты);

    // Табличные части (для справочников, документов)
    Если ЕстьКоллекция(ОбъектМД, "ТабличныеЧасти") Тогда
        ТЧ = Новый Массив;
        Для Каждого ТабличнаяЧасть Из ОбъектМД.ТабличныеЧасти Цикл
            ОписаниеТЧ = Новый Структура;
            ОписаниеТЧ.Вставить("name", ТабличнаяЧасть.Имя);
            РеквизитыТЧ = Новый Массив;
            Для Каждого Реквизит Из ТабличнаяЧасть.Реквизиты Цикл
                Описание = Новый Структура;
                Описание.Вставить("name", Реквизит.Имя);
                Описание.Вставить("synonym", Реквизит.Синоним);
                Описание.Вставить("type", Строка(Реквизит.Тип));
                РеквизитыТЧ.Добавить(Описание);
            КонецЦикла;
            ОписаниеТЧ.Вставить("attributes", РеквизитыТЧ);
            ТЧ.Добавить(ОписаниеТЧ);
        КонецЦикла;
        Результат.Вставить("tabularParts", ТЧ);
    КонецЕсли;

    // Измерения (для регистров)
    Если ЕстьКоллекция(ОбъектМД, "Измерения") Тогда
        Измерения = Новый Массив;
        Для Каждого Измерение Из ОбъектМД.Измерения Цикл
            Описание = Новый Структура;
            Описание.Вставить("name", Измерение.Имя);
            Описание.Вставить("synonym", Измерение.Синоним);
            Описание.Вставить("type", Строка(Измерение.Тип));
            Измерения.Добавить(Описание);
        КонецЦикла;
        Результат.Вставить("dimensions", Измерения);
    КонецЕсли;

    // Ресурсы (для регистров)
    Если ЕстьКоллекция(ОбъектМД, "Ресурсы") Тогда
        Ресурсы = Новый Массив;
        Для Каждого Ресурс Из ОбъектМД.Ресурсы Цикл
            Описание = Новый Структура;
            Описание.Вставить("name", Ресурс.Имя);
            Описание.Вставить("synonym", Ресурс.Синоним);
            Описание.Вставить("type", Строка(Ресурс.Тип));
            Ресурсы.Добавить(Описание);
        КонецЦикла;
        Результат.Вставить("resources", Ресурсы);
    КонецЕсли;

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрокаJSON(Результат));
    Возврат Ответ;
КонецФункции

// НайтиМетаданныеПоТипуИИмени — вспомогательная функция поиска объекта метаданных
// по английскому имени типа и имени объекта.
// Используется в обработчиках object.bsl и module.bsl.
// В реальном расширении рекомендуется вынести в общий модуль.
Функция НайтиМетаданныеПоТипуИИмени(ТипОбъекта, ИмяОбъекта)
    Соответствие = Новый Соответствие;
    Соответствие.Вставить("Catalog",                      Метаданные.Справочники);
    Соответствие.Вставить("Document",                     Метаданные.Документы);
    Соответствие.Вставить("Enum",                         Метаданные.Перечисления);
    Соответствие.Вставить("DataProcessor",                Метаданные.Обработки);
    Соответствие.Вставить("Report",                       Метаданные.Отчеты);
    Соответствие.Вставить("InformationRegister",          Метаданные.РегистрыСведений);
    Соответствие.Вставить("AccumulationRegister",         Метаданные.РегистрыНакопления);
    Соответствие.Вставить("AccountingRegister",           Метаданные.РегистрыБухгалтерии);
    Соответствие.Вставить("CalculationRegister",          Метаданные.РегистрыРасчета);
    Соответствие.Вставить("ChartOfAccounts",              Метаданные.ПланыСчетов);
    Соответствие.Вставить("ChartOfCharacteristicTypes",   Метаданные.ПланыВидовХарактеристик);
    Соответствие.Вставить("ChartOfCalculationTypes",      Метаданные.ПланыВидовРасчета);
    Соответствие.Вставить("ExchangePlan",                 Метаданные.ПланыОбмена);
    Соответствие.Вставить("BusinessProcess",              Метаданные.БизнесПроцессы);
    Соответствие.Вставить("Task",                         Метаданные.Задачи);

    Коллекция = Соответствие[ТипОбъекта];
    Если Коллекция = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    Возврат Коллекция.Найти(ИмяОбъекта, "Имя");
КонецФункции

// ЕстьКоллекция — проверяет наличие коллекции у объекта метаданных.
// Разные типы объектов имеют разный набор коллекций (ТабличныеЧасти, Измерения, Ресурсы).
Функция ЕстьКоллекция(ОбъектМД, ИмяКоллекции)
    Попытка
        ОбъектМД[ИмяКоллекции];
        Возврат Истина;
    Исключение
        Возврат Ложь;
    КонецПопытки;
КонецФункции
