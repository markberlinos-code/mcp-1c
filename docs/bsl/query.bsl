// Обработчик POST /query
// Выполняет запрос на языке запросов 1С (только SELECT/ВЫБРАТЬ).
//
// Тело запроса: JSON {"query": "ВЫБРАТЬ ...", "limit": 100}
// Ответ: JSON {"columns": [...], "rows": [[...], ...], "total": N, "truncated": true/false}
//
// БЕЗОПАСНОСТЬ: Сервер-сторона дополнительно проверяет,
// что запрос начинается с ВЫБРАТЬ/SELECT.

Функция ЗапросPOST(Запрос)
    ТелоJSON = Запрос.ПолучитьТелоКакСтроку();
    Параметры = ПрочитатьJSON(ТелоJSON);

    ТекстЗапроса = Параметры.query;
    Лимит = 100;
    Если Параметры.Свойство("limit") И Параметры.limit > 0 Тогда
        Лимит = Мин(Параметры.limit, 1000);
    КонецЕсли;

    // Проверка: только SELECT/ВЫБРАТЬ
    Префикс = ВРег(СокрЛП(Лев(ТекстЗапроса, 10)));
    Если Лев(Префикс, 7) <> "ВЫБРАТЬ" И Лев(Префикс, 6) <> "SELECT" Тогда
        Ответ = Новый HTTPСервисОтвет(400);
        Ответ.УстановитьТелоИзСтроки("{""error"": ""Only SELECT queries allowed""}");
        Возврат Ответ;
    КонецЕсли;

    Попытка
        Запрос1С = Новый Запрос(ТекстЗапроса);
        РезультатЗапроса = Запрос1С.Выполнить();
    Исключение
        Ответ = Новый HTTPСервисОтвет(400);
        Ответ.УстановитьТелоИзСтроки("{""error"": """ + ОписаниеОшибки() + """}");
        Возврат Ответ;
    КонецПопытки;

    Выборка = РезультатЗапроса.Выбрать();

    // Колонки
    Колонки = Новый Массив;
    Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
        Колонки.Добавить(Колонка.Имя);
    КонецЦикла;

    // Строки
    Строки = Новый Массив;
    Счетчик = 0;
    Усечено = Ложь;
    Пока Выборка.Следующий() Цикл
        Если Счетчик >= Лимит Тогда
            Усечено = Истина;
            Прервать;
        КонецЕсли;
        Строка = Новый Массив;
        Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
            Значение = Выборка[Колонка.Имя];
            Строка.Добавить(ПривестиЗначениеКJSON(Значение));
        КонецЦикла;
        Строки.Добавить(Строка);
        Счетчик = Счетчик + 1;
    КонецЦикла;

    Результат = Новый Структура;
    Результат.Вставить("columns", Колонки);
    Результат.Вставить("rows", Строки);
    Результат.Вставить("total", Счетчик);
    Результат.Вставить("truncated", Усечено);

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрокаJSON(Результат));
    Возврат Ответ;
КонецФункции

// ПривестиЗначениеКJSON — приводит значение 1С к типу, пригодному для JSON-сериализации.
// Числа и булевы передаются как есть, остальное приводится к строке.
Функция ПривестиЗначениеКJSON(Значение)
    Если Значение = Неопределено ИЛИ Значение = NULL Тогда
        Возврат "";
    ИначеЕсли ТипЗнч(Значение) = Тип("Число") ИЛИ ТипЗнч(Значение) = Тип("Булево") Тогда
        Возврат Значение;
    Иначе
        Возврат Строка(Значение);
    КонецЕсли;
КонецФункции

// ПрочитатьJSON — десериализует JSON-строку в объект 1С (Структура/Массив/Соответствие).
// Используется во всех обработчиках, принимающих JSON в теле запроса.
// В реальном расширении рекомендуется вынести в общий модуль.
Функция ПрочитатьJSON(СтрокаJSON)
    ЧтениеJSON = Новый ЧтениеJSON;
    ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
    Результат = ПрочитатьJSON(ЧтениеJSON);
    ЧтениеJSON.Закрыть();
    Возврат Результат;
КонецФункции

// СтрокаJSON — сериализует объект 1С в JSON-строку.
// Используется во всех обработчиках для формирования ответа.
// В реальном расширении рекомендуется вынести в общий модуль.
Функция СтрокаJSON(Значение)
    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Значение);
    Возврат ЗаписьJSON.Закрыть();
КонецФункции
