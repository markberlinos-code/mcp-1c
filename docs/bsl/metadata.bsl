// Обработчик GET /metadata
// Возвращает дерево метаданных конфигурации: все типы объектов и их имена.
//
// Ответ: JSON-объект, где ключ — тип метаданных, значение — массив имён.
// Пример: {"Справочники": ["Контрагенты", "Номенклатура"], "Документы": [...]}

Функция МетаданныеGET(Запрос)
    Результат = Новый Структура;

    КоллекцииМетаданных = Новый Структура;
    КоллекцииМетаданных.Вставить("Справочники",              Метаданные.Справочники);
    КоллекцииМетаданных.Вставить("Документы",                Метаданные.Документы);
    КоллекцииМетаданных.Вставить("Перечисления",             Метаданные.Перечисления);
    КоллекцииМетаданных.Вставить("Обработки",                Метаданные.Обработки);
    КоллекцииМетаданных.Вставить("Отчеты",                   Метаданные.Отчеты);
    КоллекцииМетаданных.Вставить("РегистрыСведений",         Метаданные.РегистрыСведений);
    КоллекцииМетаданных.Вставить("РегистрыНакопления",       Метаданные.РегистрыНакопления);
    КоллекцииМетаданных.Вставить("РегистрыБухгалтерии",      Метаданные.РегистрыБухгалтерии);
    КоллекцииМетаданных.Вставить("РегистрыРасчета",          Метаданные.РегистрыРасчета);
    КоллекцииМетаданных.Вставить("ПланыСчетов",              Метаданные.ПланыСчетов);
    КоллекцииМетаданных.Вставить("ПланыВидовХарактеристик",  Метаданные.ПланыВидовХарактеристик);
    КоллекцииМетаданных.Вставить("ПланыВидовРасчета",        Метаданные.ПланыВидовРасчета);
    КоллекцииМетаданных.Вставить("ПланыОбмена",              Метаданные.ПланыОбмена);
    КоллекцииМетаданных.Вставить("БизнесПроцессы",           Метаданные.БизнесПроцессы);
    КоллекцииМетаданных.Вставить("Задачи",                   Метаданные.Задачи);
    КоллекцииМетаданных.Вставить("ЖурналыДокументов",        Метаданные.ЖурналыДокументов);
    КоллекцииМетаданных.Вставить("Константы",                Метаданные.Константы);
    КоллекцииМетаданных.Вставить("ОбщиеМодули",              Метаданные.ОбщиеМодули);
    КоллекцииМетаданных.Вставить("ОбщиеФормы",               Метаданные.ОбщиеФормы);
    КоллекцииМетаданных.Вставить("ОбщиеКоманды",             Метаданные.ОбщиеКоманды);
    КоллекцииМетаданных.Вставить("ОбщиеМакеты",              Метаданные.ОбщиеМакеты);
    КоллекцииМетаданных.Вставить("Роли",                     Метаданные.Роли);
    КоллекцииМетаданных.Вставить("Подсистемы",               Метаданные.Подсистемы);
    КоллекцииМетаданных.Вставить("РегулярныеЗадания",        Метаданные.РегулярныеЗадания);
    КоллекцииМетаданных.Вставить("ВебСервисы",               Метаданные.ВебСервисы);
    КоллекцииМетаданных.Вставить("HTTPСервисы",              Метаданные.HTTPСервисы);

    Для Каждого КлючИЗначение Из КоллекцииМетаданных Цикл
        Имена = Новый Массив;
        Для Каждого ОбъектМетаданных Из КлючИЗначение.Значение Цикл
            Имена.Добавить(ОбъектМетаданных.Имя);
        КонецЦикла;
        Результат.Вставить(КлючИЗначение.Ключ, Имена);
    КонецЦикла;

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрокаJSON(Результат));
    Возврат Ответ;
КонецФункции
